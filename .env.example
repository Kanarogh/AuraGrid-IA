# =============================================================================
# AuraGrid IA — variáveis para deploy na Vercel (produção)
# Copie para o painel: Project → Settings → Environment Variables
# =============================================================================

# Opcional: hint para primeiro frame (postgresql | local). Health check ainda roda.
# NEXT_PUBLIC_STORAGE_MODE=postgresql

DATABASE_URL="postgresql://usuario:senha@host:porta/banco"
# Square Cloud: baixe certificate.pem e use um dos dois:
# DATABASE_SSL_CERT_PATH=certs/certificate.pem
# DATABASE_SSL_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# --- Armazenamento de mídia (fotos do catálogo) ---
# Square Cloud Blob (recomendado na Square Cloud):
# SQUARECLOUD_BLOB_API_KEY=sua-chave-api-da-conta
# MEDIA_STORAGE=squareblob
# SQUARECLOUD_BLOB_EXPIRE_DAYS=365

# MinIO / S3 (dev local ou R2/S3):
# MINIO_ENDPOINT="localhost"
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY="auragrid"
# MINIO_SECRET_KEY="auragridsecret"
# MINIO_BUCKET="auragrid-media"
# MEDIA_STORAGE=minio

# --- Auth JWT (gere string longa e aleatória) ---
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS=30

# Provedor ativo: gemini | groq | openrouter  (ollama só em dev local)
AI_PROVIDER=groq

# --- Google Gemini (embeddings + opcional visão) ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_CATALOG_MODEL=gemini-2.5-flash-lite
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# --- Groq ---
# GROQ_API_KEY=
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- OpenRouter ---
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Cadeia entre provedores quando o primário falha (429, timeout):
# AI_ALLOW_FALLBACK=1

# --- Match otimizado ---
# MATCH_RANKER_FAST_PATH=1
# MATCH_TEXT_ONLY=1
# MATCH_TEXT_ONLY_FALLBACK_VISION=1
# MATCH_TRUST_VISION_ON_REJECT=1
# MATCH_EMBEDDING_ENABLED=1
# MATCH_EMBEDDING_TOP_K=24

# Força modo nuvem mesmo fora da Vercel (opcional):
# AURAGRID_CLOUD_DEPLOY=1

# Logs de sync realtime (browser console + logs do servidor)
# Opção 1 — no browser (sem rebuild): localStorage.setItem('auragrid:sync-debug','1') + F5
# Opção 2 — build/deploy:
# NEXT_PUBLIC_SYNC_DEBUG=1
# SYNC_DEBUG=1

# =============================================================================
# Desenvolvimento local (npm run dev) — docker-compose para Postgres + MinIO
# =============================================================================
# DATABASE_URL="postgresql://auragrid:auragrid@localhost:5432/auragrid"
# MINIO_ENDPOINT="localhost"
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY="auragrid"
# MINIO_SECRET_KEY="auragridsecret"
# Ollama local (somente dev): OLLAMA_BASE_URL=http://127.0.0.1:11434
