# =============================================================================
# AuraGrid IA — variáveis para deploy (Gemini-only)
# =============================================================================

# Opcional: hint para primeiro frame (postgresql | local)
# NEXT_PUBLIC_STORAGE_MODE=postgresql

DATABASE_URL="postgresql://usuario:senha@host:porta/banco"
# DATABASE_SSL_CERT_PATH=certs/certificate.pem
# DATABASE_SSL_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# --- Armazenamento de mídia ---
# SQUARECLOUD_BLOB_API_KEY=sua-chave-api-da-conta
# MEDIA_STORAGE=squareblob
# SQUARECLOUD_BLOB_EXPIRE_DAYS=365

# MinIO / S3
# MINIO_ENDPOINT="localhost"
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY="auragrid"
# MINIO_SECRET_KEY="auragridsecret"
# MINIO_BUCKET="auragrid-media"
# MEDIA_STORAGE=minio

# --- Auth JWT ---
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS=30

# --- Google Gemini (Gemini-only) ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_PLANNING_MODEL=gemini-3.1-flash-lite
# GEMINI_INDEXING_MODEL=gemini-2.5-flash-lite
# GEMINI_REFERENCE_MODEL=gemini-3.1-flash-lite
# GEMINI_CONTENT_SCHEDULE_MODEL=gemini-3.1-flash-lite
# GEMINI_CATALOG_MODEL=gemini-2.5-flash-lite
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# --- Limites internos de uso IA (dashboard) ---
# AI_USAGE_DEFAULT_MONTHLY_TOKEN_LIMIT=15000000
# AI_USAGE_DEFAULT_MONTHLY_USD_LIMIT=25
# NEXT_PUBLIC_USD_TO_BRL=5.5

# --- Quota Google (opcional, best-effort) ---
# GOOGLE_QUOTA_PROJECT_ID=
# GOOGLE_QUOTA_ACCESS_TOKEN=
# GOOGLE_QUOTA_METRIC=

# --- Match otimizado ---
# MATCH_RANKER_FAST_PATH=1
# MATCH_TEXT_ONLY=1
# MATCH_TEXT_ONLY_FALLBACK_VISION=1
# MATCH_TRUST_VISION_ON_REJECT=1
# MATCH_EMBEDDING_ENABLED=1
# MATCH_EMBEDDING_TOP_K=24

# Força modo nuvem mesmo fora da Vercel (opcional)
# AURAGRID_CLOUD_DEPLOY=1

# Logs de sync no servidor
# SYNC_DEBUG=1
# NEXT_PUBLIC_SYNC_DEBUG=1

# =============================================================================
# Desenvolvimento local (npm run dev)
# =============================================================================
# DATABASE_URL="postgresql://auragrid:auragrid@localhost:5432/auragrid"
# MINIO_ENDPOINT="localhost"
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY="auragrid"
# MINIO_SECRET_KEY="auragridsecret"
