# Provedor ativo: gemini | groq | deepseek | openrouter
AI_PROVIDER=gemini

# --- Google Gemini ---
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# GEMINI_MODEL="gemini-2.0-flash"

# --- Groq (Llama 4 Scout com visão) ---
GROQ_API_KEY="MY_GROQ_API_KEY"
# GROQ_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# --- DeepSeek (texto: refinamento; legendas com foto usam Groq, Gemini ou OpenRouter abaixo) ---
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"
# DEEPSEEK_MODEL="deepseek-v4-flash"

# --- OpenRouter (3º fallback para visão, free tier) ---
# Crie em https://openrouter.ai/keys (gratuito). Modelos free com visão:
#   google/gemma-4-31b-it:free                        (visão, recomendado — catálogo/legendas)
#   google/gemma-4-26b-a4b-it:free                    (visão MoE, texto+imagem+vídeo curto)
#   qwen/qwen2.5-vl-32b-instruct:free                 (visão)
#   openrouter/free                                 (roteador; último recurso no catálogo)
#   minimax/minimax-m2.5:free                       (texto, grátis, ótimo em legendas)
#   minimax/minimax-m2.7                            (texto, pago)
OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="openrouter/free"

APP_URL="http://localhost:3000"

# Logs detalhados de IA no terminal (tentativas, tipo de falha, corpo parcial)
# AI_DEBUG=1
