# --- PostgreSQL (persistência multi-usuário) ---
DATABASE_URL="postgresql://auragrid:auragrid@localhost:5432/auragrid"

# --- MinIO (blob storage para fotos) ---
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="auragrid"
MINIO_SECRET_KEY="auragridsecret"
MINIO_BUCKET="auragrid-media"

# --- Auth JWT ---
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS=30

# Provedor ativo: gemini | groq | openrouter | ollama
AI_PROVIDER=gemini

# --- Google Gemini (recomendado: qualidade + cota previsível) ---
# GEMINI_API_KEY=sua-chave-em-aistudio.google.com
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_CATALOG_MODEL=gemini-2.5-flash-lite

# --- Groq (rápido; Llama 4 Scout tem visão) ---
# GROQ_API_KEY=sua-chave-em-console.groq.com
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- OpenRouter (free rotativo — use como fallback) ---
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=google/gemma-4-31b-it:free

# --- Ollama local (sem cota; precisa GPU) ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=gemma4
# OLLAMA_NUM_CTX=32768
# OLLAMA_TIMEOUT_MS=300000
# Cloud (se aparecer no app Ollama): OLLAMA_MODEL=gemma4:31b-cloud
# Visão extra (opcional): ollama pull qwen2.5vl:7b  →  OLLAMA_MODEL=qwen2.5vl:7b

# Cadeia entre provedores quando o primário falha (429, timeout, etc.):
# AI_ALLOW_FALLBACK=1

# --- Match otimizado (tokens + precisão) ---
# MATCH_RANKER_FAST_PATH=1
# MATCH_TEXT_ONLY=1
# MATCH_TEXT_ONLY_FALLBACK_VISION=1
# MATCH_TRUST_VISION_ON_REJECT=1
# MATCH_EMBEDDING_ENABLED=1
# MATCH_EMBEDDING_TOP_K=24
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2